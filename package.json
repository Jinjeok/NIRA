{
  "dependencies": {
    "@google/genai": "^1.5.0",
    "@google/generative-ai": "^0.24.1",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "axios": "^1.9.0",
    "crawler": "^2.0.2",
    "discord-api-types": "^0.38.9",
    "discord.js": "^14.26.4",
    "dotenv": "^16.5.0",
    "mathjs": "^15.2.0",
    "moment": "^2.30.1",
    "node-cron": "^4.1.0",
    "nodemon": "^3.1.10",
    "rss-parser": "^3.13.0",
    "winston": "^3.17.0",
    "winston-daily-rotate-file": "^5.0.0",
    "yarn": "^1.22.22"
  },
  "name": "nira",
  "description": "Discord Bot for useful daily tasks",
  "version": "0.0.1",
  "main": "index.js",
  "type": "module",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "node --no-warnings src/runtime/startAll.js",
    "start:all": "node --no-warnings src/runtime/startAll.js",
    "start:bot": "node --no-warnings index.js",
    "start:admin": "node --no-warnings src/admin/server.js",
    "migrate:local-state": "node --no-warnings scripts/migrate-local-state.js",
    "dev": "nodemon -e js --exec \"node --no-warnings src/runtime/dev.js\"",
    "dev2": "nodemon -e js --exec \"node --no-warnings src/runtime/dev.js --skip-deploy\"",
    "deploy": "node deploy-commands.js",
    "delete-commands": "node delete-commands.js",
    "generate-docs": "node scripts/generate-docs.js",
    "docs:generate": "npm run generate-docs",
    "docs:dev": "cd docs && npm start",
    "docs:build": "cd docs && npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jinjeok/NIRA.git"
  },
  "author": "Jinjeok",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Jinjeok/NIRA/issues"
  },
  "homepage": "https://jinjeok.github.io/NIRA/"
}
